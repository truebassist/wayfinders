  .updated {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  ul {
    padding-left: 1.5rem;
    margin: 0.75rem 0 1rem;
  }
  ul li { margin-bottom: 0.35rem; }
</style>
